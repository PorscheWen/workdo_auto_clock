# Workdo API 設定範本
# 複製此檔案為 .env 並填入實際資料

# Workdo 帳號資訊
WORKDO_EMAIL=your_email@example.com
WORKDO_PASSWORD=your_password
WORKDO_COMPANY_ID=your_company_id

# 💡 如何取得 Company ID？請參考 docs/GET_COMPANY_ID.md
# 範例 1: https://www.workdo.co/!#/aa6pd97f/... → Company ID = aa6pd97f
# 範例 2: https://app.workdo.co/company/12345/... → Company ID = 12345

# Workdo API 網址（請依實際情況修改）
WORKDO_API_URL=https://api.workdo.co

# 打卡時間設定（選用，可在程式中覆寫）
CLOCK_IN_TIME=09:00
CLOCK_OUT_TIME=18:00
