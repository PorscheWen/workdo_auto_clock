# Workdo 帳號設定
WORKDO_EMAIL=your_email@example.com
WORKDO_PASSWORD=your_password

# GPS 位置設定（選填，預設為台北市信義區）
WORKDO_GPS_LOCATION=25.033,121.564
WORKDO_GPS_PLACE=台北市信義區

# 是否使用 Workdo API 查詢假日（true/false）
WORKDO_USE_LEAVE_API=false

# 是否併用台灣公開行事曆略過國定假日（預設 true；與 leave_days.json、Workdo API 並用）
WORKDO_USE_TW_CALENDAR=true
